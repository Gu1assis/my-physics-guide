---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

// Buscar todos os posts que não estão em draft
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Ordenar posts por data (mais recentes primeiro)
const posts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="Home">
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="max-w-5xl mx-auto px-6 py-16 md:py-24">
      <div class="space-y-6">
        <div class="flex gap-8">
          <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-light-text dark:text-dark-text">
            Guia para a Física
          </h1>
          <ThemeToggle />
        </div>

        <p class="text-xl md:text-2xl text-light-subtext0 dark:text-dark-subtext0 max-w-2xl leading-relaxed">
          Meu blog de conceitos, demonstrações, reflexões e conversas sobre física e filosofia. Escrito pra estudantes e para mim mesmo.
        </p>

        <div class="h-1 w-16 bg-light-mauve dark:bg-dark-mauve rounded-full"></div>
      </div>
    </section>

    <!-- Search Section -->
    <section class="max-w-5xl mx-auto px-6 mb-12">
      <div class="relative">
        <input
          type="text"
          id="searchInput"
          placeholder="Buscar posts..."
          class="w-full px-4 py-3 rounded-lg border border-light-surface1 dark:border-dark-surface1 bg-white dark:bg-dark-mantle text-light-text dark:text-dark-text placeholder-light-subtext0 dark:placeholder-dark-subtext0 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-light-mauve dark:focus:ring-dark-mauve focus:border-transparent"
        />
        <svg class="absolute right-4 top-3.5 w-5 h-5 text-light-subtext0 dark:text-dark-subtext0 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="max-w-5xl mx-auto px-6 pb-16">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="postsContainer">
          {posts.map((post) => (
            <div class="search-item" data-title={post.data.title.toLowerCase()} data-description={post.data.description.toLowerCase()}>
              <PostCard title={post.data.title} description={post.data.description} image={post.data.image} url={`/posts/${post.slug}/`} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-light-subtext0 dark:text-dark-subtext0">Nenhum post publicado ainda.</p>
        </div>
      )}

      <!-- Placeholder para anúncio -->
      <div class="mt-16 p-8 rounded-lg border-2 border-dashed border-light-surface1 dark:border-dark-surface1 text-center">
        <p class="text-light-subtext0 dark:text-dark-subtext0 italic">
          &lt;!-- Espaço reservado  --&gt;
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const searchInput = document.getElementById('searchInput');
  const searchItems = document.querySelectorAll('.search-item');

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();

    searchItems.forEach((item) => {
      const title = item.getAttribute('data-title') || '';
      const description = item.getAttribute('data-description') || '';
      const matches = title.includes(query) || description.includes(query);

      if (matches || query === '') {
        item.classList.remove('hidden');
        item.classList.add('block');
      } else {
        item.classList.add('hidden');
        item.classList.remove('block');
      }
    });
  });
</script>
